{
  "manifest_version": 3,
  "name": "Shorts Remover",
  "version": "1.0.0",
  "description": "Removes YouTube Shorts from feed surfaces and navigation.",
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
